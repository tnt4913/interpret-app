/* pages/call/call.wxss */
.call-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0F0F1A;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(26, 26, 46, 0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  flex-shrink: 0;
}

.status-left {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.status-dot.recording {
  background: #f5576c;
  box-shadow: 0 0 12rpx #f5576c;
  animation: pulse 1.5s ease-in-out infinite;
}

.status-dot.idle {
  background: #6B7280;
}

.status-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

.timer {
  font-size: 30rpx;
  font-weight: 600;
  color: #E0E0E0;
  font-variant-numeric: tabular-nums;
}

/* 翻译区 */
.translation-area {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.section-label {
  font-size: 24rpx;
  color: #6B7280;
  padding: 8rpx 16rpx;
  margin-bottom: 20rpx;
}

/* 消息项 */
.msg-item {
  margin-bottom: 24rpx;
  animation: fadeIn 0.4s ease-out;
}

.msg-other {
  display: flex;
  justify-content: flex-start;
}

.msg-mine {
  display: flex;
  justify-content: flex-end;
  align-items: flex-start;
}

.msg-bubble {
  max-width: 85%;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  position: relative;
}

.other-bubble {
  background: linear-gradient(135deg, #1E293B 0%, #334155 100%);
  border-top-left-radius: 8rpx;
}

.mine-bubble {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-top-right-radius: 8rpx;
  margin-right: 16rpx;
}

.msg-original {
  font-size: 30rpx;
  color: #F0F0F0;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.mine-bubble .msg-original {
  color: #fff;
}

.msg-translated {
  display: flex;
  align-items: flex-start;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.lang-tag {
  font-size: 20rpx;
  background: rgba(102, 126, 234, 0.3);
  color: #a5b4fc;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.translated-text {
  font-size: 28rpx;
  color: #a5b4fc;
  line-height: 1.5;
  flex: 1;
}

.mine-bubble .translated-text {
  color: rgba(255, 255, 255, 0.85);
}

.mine-bubble .lang-tag {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.9);
}

.msg-role-tag {
  font-size: 20rpx;
  color: #9CA3AF;
  background: rgba(255, 255, 255, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
}

/* 加载动画 */
.msg-loading {
  display: flex;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.loading-dot {
  font-size: 16rpx;
  color: #667eea;
  margin-right: 6rpx;
  animation: pulse 1.4s ease-in-out infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

.loading-hint {
  font-size: 22rpx;
  color: #6B7280;
  margin-left: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #E0E0E0;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #6B7280;
}

/* AI 回答区 */
.answer-section {
  flex-shrink: 0;
  background: linear-gradient(135deg, #1A1A2E 0%, #1E1B3A 100%);
  border-top: 2rpx solid rgba(102, 126, 234, 0.3);
  border-radius: 32rpx 32rpx 0 0;
  padding: 28rpx 32rpx;
  max-height: 45vh;
  overflow-y: auto;
  animation: fadeIn 0.4s ease-out;
}

.answer-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.answer-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.answer-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  flex: 1;
}

.answer-loading {
  display: flex;
  align-items: center;
}

.answer-loading.hidden {
  display: none;
}

.answer-content {
  font-size: 28rpx;
  color: #E0E0E0;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
  padding: 20rpx;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 16rpx;
  border-left: 6rpx solid #667eea;
}

.answer-content.blurred {
  color: #6B7280;
  font-style: italic;
}

.answer-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.answer-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx 0;
  background: rgba(255, 255, 255, 0.08);
  color: #E0E0E0;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  line-height: 1.5;
}

/* 底部控制栏 */
.control-bar {
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(15, 15, 26, 0.95);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  gap: 32rpx;
}

.ctrl-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 120rpx;
  border-radius: 28rpx;
  border: none;
  padding: 0;
  line-height: 1.4;
}

.ctrl-btn::after {
  border: none;
}

.btn-start {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.btn-stop {
  background: linear-gradient(135deg, #f5576c 0%, #f093fb 100%);
  box-shadow: 0 8rpx 24rpx rgba(245, 87, 108, 0.4);
}

.btn-save {
  background: rgba(74, 222, 128, 0.15);
  border: 1rpx solid rgba(74, 222, 128, 0.3);
}

.btn-clear {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.ctrl-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.ctrl-text {
  font-size: 24rpx;
  color: #E0E0E0;
}

.btn-stop .ctrl-text,
.btn-start .ctrl-text {
  color: #fff;
}
