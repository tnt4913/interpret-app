# ===========================================
# 面试同传助手 - 后端环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥
# ===========================================
#
# 💰 免费方案说明（推荐，总费用 ¥0）：
#   - ASR（语音识别）：默认用 mock 模拟模式，无需申请
#                     如需真实识别，申请阿里云（每月免费15小时）
#   - 翻译：百度翻译（每月免费5万字，注册即送）   ← 只需填这个
#   - LLM：智谱GLM-4-Flash（永久免费）            ← 和这个
#
# 📋 你只需要做两件事：
#   1. 申请百度翻译Key → 填入下方 BAIDU_TRANSLATE_*
#   2. 申请智谱AI Key  → 填入下方 ZHIPU_API_KEY
#
# ===========================================

# 服务端口
PORT=3000

# ============ 语音识别（ASR）配置 ============
# ASR_PROVIDER 可选值：
#   mock    - 模拟模式（默认，无需Key，自动生成模拟问题测试流程）
#   aliyun  - 阿里云语音识别（每月免费15小时，需申请）
ASR_PROVIDER=mock

# --- 阿里云语音识别（如需真实识别再填写） ---
ALIYUN_ASR_APPKEY=
ALIYUN_ASR_TOKEN=
ALIYUN_ASR_URL=wss://nls-gateway.cn-shanghai.aliyuncs.com/ws/v1

# ============ 翻译 API 配置 ============
# ⭐ 必填！百度翻译（免费，注册即送5万字/月）
# 申请地址：https://fanyi-api.baidu.com/
TRANSLATE_PROVIDER=baidu
BAIDU_TRANSLATE_APPID=20260629002639569
BAIDU_TRANSLATE_KEY=90XtgiXXDuHLtGYy_zbK

# --- 阿里云翻译（备选，无需填写） ---
ALIYUN_TRANSLATE_KEY=
ALIYUN_TRANSLATE_SECRET=
ALIYUN_TRANSLATE_REGION=cn-hangzhou

# ============ AI 回答生成配置 ============
# ⭐ 必填！智谱GLM-4-Flash（永久免费，不收费！）
# 申请地址：https://open.bigmodel.cn/
LLM_PROVIDER=zhipu
ZHIPU_API_KEY=b6f638e66d35467f87eb03f144a7730f.Z3vAJejYAU9Txjv2
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- DeepSeek（备选，按量付费约¥0.1/场，无需填写） ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OpenAI（备选，无需填写） ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Moonshot/Kimi（备选，无需填写） ---
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ============ 其他 ============
CORS_ORIGIN=*
